# ─── Server ───────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mental_health_db
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SSL=false          # Set to true in production

# ─── Session ──────────────────────────────────────────
SESSION_SECRET=replace_with_a_long_random_secret_min_64_chars
SESSION_EXPIRY_HOURS=24   # Hours until session expires

# ─── Cookie ───────────────────────────────────────────
COOKIE_SECURE=false       # Set to true in production (requires HTTPS)
COOKIE_SAME_SITE=strict   # strict | lax | none

# ─── Rate Limiting ────────────────────────────────────
LOGIN_RATE_LIMIT_WINDOW_MS=900000   # 15 minutes
LOGIN_RATE_LIMIT_MAX=10             # Max login attempts per window
